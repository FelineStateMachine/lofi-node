{
  "name": "@nzip/lofi-node",
  "version": "0.1.2",
  "license": "MIT",
  "description": "Self-hostable sync node for lofi apps: an embedded Jazz sync server with iroh peer-to-peer transport and ticket-gated access. Pair homes by ticket — no static IPs, no cloud — issue revocable app tickets, and choose where your data lives.",
  "exports": {
    ".": "./mod.ts",
    "./testing": "./testing/mod.ts",
    "./cli": "./cli.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "jazz-napi": "npm:jazz-napi@2.0.0-alpha.53",
    "jazz-tools": "npm:jazz-tools@2.0.0-alpha.53",
    "jazz-tools/testing": "npm:jazz-tools@2.0.0-alpha.53/testing",
    "jazz-tools/permissions": "npm:jazz-tools@2.0.0-alpha.53/permissions"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check mod.ts cli.ts testing/mod.ts tests/",
    "test": "deno test -A tests/",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "start": "deno run -A cli.ts start",
    "compile": "deno compile -A --include native/iroh-js/prebuilt --output dist/lofi-node cli.ts",
    "compile:darwin-arm64": "deno compile -A --target aarch64-apple-darwin --include native/iroh-js/prebuilt/aarch64-apple-darwin --output dist/lofi-node-aarch64-apple-darwin cli.ts",
    "compile:linux-x64": "deno compile -A --target x86_64-unknown-linux-gnu --include native/iroh-js/prebuilt/x86_64-unknown-linux-gnu --output dist/lofi-node-x86_64-unknown-linux-gnu cli.ts",
    "compile:linux-arm64": "deno compile -A --target aarch64-unknown-linux-gnu --include native/iroh-js/prebuilt/aarch64-unknown-linux-gnu --output dist/lofi-node-aarch64-unknown-linux-gnu cli.ts",
    "native": "cargo build --release --manifest-path native/iroh-js/Cargo.toml",
    "release:artifacts": "deno run --allow-read --allow-write=src/native/artifacts.ts tools/release_artifacts.ts && deno fmt src/native/artifacts.ts",
    "publish:dry": "deno publish --dry-run"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.ts",
      "cli.ts",
      "src",
      "testing",
      "docs/app-ticket.md",
      "docs/hosting-lofi-apps.md",
      "docs/fixtures"
    ],
    "exclude": [
      "native",
      "tests",
      "dist"
    ]
  },
  "fmt": {
    "lineWidth": 100,
    "exclude": ["native/iroh-js/"]
  },
  "lint": {
    "exclude": ["native/iroh-js/"]
  }
}
